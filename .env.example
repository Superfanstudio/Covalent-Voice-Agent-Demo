# Copy to .env for local dev. On Vercel, set these in Project → Settings → Environment Variables.

# AssemblyAI — mints single-use voice-agent tokens (required for voice)
ASSEMBLYAI_API_KEY=

# Supabase (project: covalent-feedback / wxividqrrmsbuaxncpsn) — server-side only
SUPABASE_URL=https://wxividqrrmsbuaxncpsn.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# OpenRouter — all server-side Claude calls (version generation, Agent Mode,
# memory, coverage) route through lib/llm.js with this key
OPENROUTER_API_KEY=
# ANTHROPIC_MODEL=claude-opus-4-8     (version generation / Agent Mode drafts)
# MEMORY_MODEL=claude-fable-5         (per-function memory + coverage, 1M context)

# Access code required by "New version", Agent Mode, and memory refresh (server-side check; pick your own)
VERSION_ACCESS_CODE=

# Optional: protect admin API routes (/api/kb ingest/seed/delete)
# ADMIN_PASSWORD=

# Optional: PostHog analytics (incl. LLM generation tracking via @posthog/ai)
# POSTHOG_PROJECT_TOKEN=
# POSTHOG_HOST=https://us.i.posthog.com
