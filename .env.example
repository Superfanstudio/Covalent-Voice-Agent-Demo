# Copy to .env for local dev. On Vercel, set these in Project → Settings → Environment Variables.

# AssemblyAI — mints single-use voice-agent tokens (required for voice)
ASSEMBLYAI_API_KEY=

# Supabase (project: covalent-feedback / wxividqrrmsbuaxncpsn) — server-side only
SUPABASE_URL=https://wxividqrrmsbuaxncpsn.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic — powers "Generate new version" and Kee's long-term memory
ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-opus-4-8     (version generation)
# MEMORY_MODEL=claude-fable-5         (workbook memory / AI brain, 1M context)

# Access code required by the "New version" button (server-side check; pick your own)
VERSION_ACCESS_CODE=

# Optional: protect /admin and admin API routes
# ADMIN_PASSWORD=

# Optional: PostHog analytics
# POSTHOG_PROJECT_TOKEN=
# POSTHOG_HOST=https://us.i.posthog.com
